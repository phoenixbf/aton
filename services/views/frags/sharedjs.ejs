<script>
/*
    Shared routines across V2 backend UI
============================================*/

let SHU = {};
window.SHU = SHU;

SHU.SCENE_BASE = {
    visibility:0,

    scenegraph: {
        nodes: {
            main: {}
        },
        edges: {
            ".": ["main"]
        }
    }
};

SHU.setPageWaiting = ()=>{
    ATON.UI.showCenteredOverlay();
};

SHU.setPageComplete = ()=>{
    ATON.UI.hideCenteredOverlay();
};

SHU.createTextBlock = (content)=>{
    let el = ATON.UI.createContainer({
        classes: "shuTextBlock"
    });

    if (content) el.append(content);

    return el;
};

SHU.createMainAuthDropdown = (u, section)=>{

    const items = [];

    //if (section!=="myscenes")     items.push({ title: "My Scenes", url: "/myscenes", icon:"scene" });
    //if (section!=="mycollection") items.push({ title: "My Collection", url: "/mycollection", icon:"collection" });

    items.push({ 
        title: "Logout", 
        url: "/logout", 
        icon: "exit" 
    });

    return ATON.UI.createDropdown({
            icon: "user",
            variant: "accent",
            align: "right",
            title: u.username,
            items: items
    });
};

SHU.createNavbarAuthSections = (section)=>{
    const items = [];
/*
    items.push({ 
        text: "My Collection",
        onpress: ()=>{window.location.href="/mycollection"},
        classes: (section==="mycollection")? "aton-btn-section-highlight": undefined,
        icon:"collection"
    });
*/
    items.push({
        text: "My Scenes",
        onpress: ()=>{window.location.href="/myscenes"},
        classes: (section==="myscenes")? "aton-btn-section-highlight": undefined,
        icon: "gallery"
    });

    const elNavbar = ATON.UI.get("navbarItems");

    for (let i in items){
        elNavbar.append( ATON.UI.createButton( items[i] ) );
    }

};

SHU.createNewScene = (options)=>{
    if (!options) options = {};

    ATON.checkAuth(
        (u)=>{
            let O = {
                data: SHU.SCENE_BASE
            }

            ATON.REQ.post("scenes/", O, (sid)=>{
                console.log(sid);

                if (options.onsuccess) options.onsuccess();
                else window.location.href="/s/"+sid+"?e=1";
            });
        }
    );
};

SHU.deleteScene = (options)=>{
    if (!options) return;
    if (!options.sid) return;

    ATON.checkAuth(
        (u)=>{
            ATON.REQ.delete("scenes/"+options.sid, (b)=>{
                console.log(b);

                if (options.onsuccess) options.onsuccess();
                else window.location.href="/myscenes/";
            });
        }
    );  
};

SHU.cloneScene = (options)=>{
    if (!options) return;
    if (!options.sid) return;

    ATON.checkAuth(
        (u)=>{
            let O = {
                fromScene: options.sid
            }

            ATON.REQ.post("scenes/", O, (newsid)=>{
                console.log(newsid);
                if (!newsid) return;

                if (options.onsuccess) options.onsuccess(newsid);
            });
        }
    );
};

</script>